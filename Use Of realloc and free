#include <stdio.h>
#include <stdlib.h>
int main()
{
    int *ptr, n, i;
    printf("Enter number of elements: ");
    scanf("%d", &n);
    ptr = (int*) malloc(n * sizeof(int));
    printf("Enter elements:\n");
    for(i = 0; i < n; i++)
    {
        scanf("%d", &ptr[i]);
    }
    ptr = realloc(ptr, (n + 2) * sizeof(int));
    printf("Enter additional elements:\n");
    for(i = n; i < n + 2; i++)
    {
        scanf("%d", &ptr[i]);
    }
    printf("Updated array elements:\n");
    for(i = 0; i < n + 2; i++)
    {
        printf("%d ", ptr[i]);
    }
    free(ptr);
    return 0;
}
